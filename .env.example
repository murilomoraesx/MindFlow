# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Porta do servidor (padrão: 3003)
PORT=3003

# Conta master (administrador)
MINDFLOW_MASTER_NAME="Murilo"
MINDFLOW_MASTER_EMAIL="murilo@example.com"
MINDFLOW_MASTER_PASSWORD="change-me"

# Diretório de dados (padrão: ~/.mindflow-data)
# MINDFLOW_DATA_DIR="/root/.mindflow-data"

# Ambiente (development ou production)
NODE_ENV=production
